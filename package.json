{
  "name": "open-swiftle",
  "version": "1.0.0",
  "description": "A Taylor Swift song guessing game inspired by Wordle",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server/index.js",
    "dev": "tsc && node dist/server/index.js",
    "setup": "tsc && node dist/scripts/setup.js",
    "watch": "tsc --watch"
  },
  "keywords": ["taylor-swift", "music", "game", "wordle"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "sqlite3": "^5.1.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "fluent-ffmpeg": "^2.1.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "@types/fluent-ffmpeg": "^2.1.21",
    "typescript": "^5.3.2"
  }
}