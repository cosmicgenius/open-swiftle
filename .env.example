# Daily seed secret - change this to make your daily songs unpredictable
# This prevents people from predicting daily songs even with access to the code
DAILY_SEED_SECRET=your_super_secret_string_here_change_this

# Server port (optional, defaults to 3000)
PORT=3000

# Spotify App Credentials (create app at https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback

# Session secret for secure sessions
SESSION_SECRET=your_session_secret_here