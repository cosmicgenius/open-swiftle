# Daily seed secret - change this to make your daily songs unpredictable
# This prevents people from predicting daily songs even with access to the code
DAILY_SEED_SECRET=your_super_secret_string_here_change_this

# Server port (optional, defaults to 3000)
PORT=3000

# Freeplay shared clip cache tuning (optional)
FREEPLAY_CLIP_TTL_MS=300000
FREEPLAY_POOL_REFRESH_MS=300000
FREEPLAY_POOL_MIN_SIZE=12
FREEPLAY_POOL_MAX_SIZE=30
FREEPLAY_AUDIO_MAX_AGE_SECONDS=60
